  _objectives:
  - _title: 'Objective: Reach the Pickup Point'
    _description: "Move the drone from the depot to the pickup point.\n\nThe pickup
      point is three tiles to the right of the depot.\n\nYou should have access to
      move functions:\n\tmove_right()\n\tmove_down()\n\tmove_left()\n\tmove_up()"
    _goalType: 1
    _requiredCount: 1
  - _title: 'Objective: Pick Up the Package'
    _description: "Collect the package...\n\nYou should have access to move functions:\n\tpick_up()\n\tdrop_off()"
    _goalType: 2
    _requiredCount: 1
  - _title: 'Objective: Complete One Delivery'
    _description: "Deliver the package...\n\nYou should have access to action and
      movement functions:\n\tpick_up()\n\tdrop_off()\n\tmove_right()\n\tmove_down()\n\tmove_left()\n\tmove_up()"
    _goalType: 3
    _requiredCount: 1
